{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "..",
  "testEnvironment": "node",
  "testMatch": ["<rootDir>/test/unit/**/*.spec.ts"],
  "transform": {
    "^.+\\.(t|j)s$": [
      "ts-jest",
      {
        "tsconfig": {
          "types": ["node", "jest"]
        }
      }
    ]
  },
  "collectCoverageFrom": ["<rootDir>/src/**/*.ts"],
  "coverageDirectory": "<rootDir>/coverage/unit"
}
